* { box-sizing: border-box; }
:root {
  --bg: #f5f7fb;
  --card: #ffffff;
  --line: #dbe3ef;
  --text: #17212b;
  --muted: #5d6b7c;
  --primary: #155eef;
  --primary-soft: #e8f0ff;
  --success: #0f9d58;
  --warning: #f59e0b;
  --danger: #d92d20;
  --amazon: #ff9900;
  --rakuten: #bf0000;
  --yahoo: #ff0033;
}
body {
  margin: 0;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  color: var(--text);
  background: var(--bg);
}
.container { width: min(1120px, calc(100% - 32px)); margin: 0 auto; }
.site-header {
  background: linear-gradient(135deg, #0b3aa4, #155eef 60%, #4b86ff);
  color: white;
  padding: 48px 0 40px;
}
.eyebrow { text-transform: uppercase; letter-spacing: .08em; font-size: 12px; opacity: .9; margin: 0 0 8px; }
h1 { margin: 0 0 12px; font-size: clamp(28px, 4vw, 42px); }
.lead { margin: 0; max-width: 860px; line-height: 1.7; opacity: .95; }
.header-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 20px; }
.top-nav {
  display: flex; gap: 12px; flex-wrap: wrap;
  padding: 16px 0;
}
.top-nav a { color: var(--primary); text-decoration: none; font-weight: 600; }
main { padding: 8px 0 32px; }
.card {
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 8px 20px rgba(16, 24, 40, .04);
}
.grid-two {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 20px;
}
.monetization .cta-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin: 16px 0;
}
.shop-link, .btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44px;
  padding: 10px 14px;
  border-radius: 10px;
  text-decoration: none;
  font-weight: 700;
  border: 1px solid var(--line);
  background: white;
  color: var(--text);
  cursor: pointer;
}
.btn.primary { background: var(--primary); color: white; border-color: var(--primary); }
.shop-link.amazon { border-color: var(--amazon); color: var(--amazon); }
.shop-link.rakuten { border-color: var(--rakuten); color: var(--rakuten); }
.shop-link.yahoo { border-color: var(--yahoo); color: var(--yahoo); }
.ad-box {
  min-height: 90px;
  border: 2px dashed var(--line);
  border-radius: 12px;
  display: grid;
  place-items: center;
  color: var(--muted);
  background: #fafcff;
}
.settings-grid, .settings-actions {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  align-items: center;
}
.shop-selector { margin: 16px 0; }
.toggle-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 10px;
}
.toggle-card {
  padding: 10px 12px;
  border: 1px solid var(--line);
  border-radius: 10px;
  background: #fbfcfe;
}
table {
  width: 100%;
  border-collapse: collapse;
}
th, td {
  text-align: left;
  padding: 12px 10px;
  border-bottom: 1px solid var(--line);
  vertical-align: top;
}
thead th {
  font-size: 13px;
  color: var(--muted);
}
.feed-list { display: grid; gap: 12px; }
.feed-item {
  border: 1px solid var(--line);
  border-radius: 12px;
  padding: 14px;
  background: #fcfdff;
}
.feed-item .meta {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  font-size: 12px;
  color: var(--muted);
  margin-bottom: 8px;
}
.feed-item h3 { margin: 0 0 6px; font-size: 16px; }
.feed-item a { color: var(--primary); text-decoration: none; font-weight: 700; }
.tag {
  display: inline-flex;
  align-items: center;
  height: 24px;
  padding: 0 8px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 700;
}
.tag.lottery { background: #e8f0ff; color: #155eef; }
.tag.commerce { background: #fff1e6; color: #b54708; }
.tag.twitter { background: #eef4ff; color: #2f55d4; }
.status-open { color: var(--success); font-weight: 700; }
.status-soon { color: var(--warning); font-weight: 700; }
.status-closed { color: var(--danger); font-weight: 700; }
.small-title { font-weight: 700; margin: 0 0 10px; }
.helper, .muted { color: var(--muted); }
.bullet-list { margin: 0; padding-left: 18px; line-height: 1.8; }
.site-footer {
  padding: 20px 0 36px;
  color: var(--muted);
}
.article, .page {
  max-width: 860px;
}
.article h1, .page h1 { color: var(--text); font-size: 34px; }
.article h2, .page h2 { margin-top: 28px; }
.notice {
  border-left: 4px solid var(--primary);
  padding: 12px 14px;
  background: var(--primary-soft);
  border-radius: 8px;
}
@media (max-width: 880px) {
  .grid-two, .monetization .cta-grid { grid-template-columns: 1fr; }
  th:nth-child(4), td:nth-child(4) { min-width: 180px; }
}
